{
  "id": null,
  "uid": "aiops-service-health",
  "title": "Service Health",
  "tags": ["aiops", "services"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Throughput (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_throughput_requests_per_sec",
          "legendFormat": "Throughput",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_error_rate_percent",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Response Time (s)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_response_time_seconds",
          "legendFormat": "Response Time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "DB Connections",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_database_connections",
          "legendFormat": "DB Connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Throughput Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_throughput_requests_per_sec",
          "legendFormat": "Req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_error_rate_percent",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Response Time Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_response_time_seconds",
          "legendFormat": "Response Time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "DB Connections Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_database_connections",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ]
    }
  ]
}
