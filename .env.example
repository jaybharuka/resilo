# AIOps Bot Configuration
# Copy this to .env and fill in your actual values

# =======================================================================
# REQUIRED — app will exit at startup if any of these are missing or empty
# =======================================================================

# PostgreSQL connection string (asyncpg format)
DATABASE_URL=replace-with-your-postgresql-connection-string

# Secret key for signing JWT tokens (min 32 chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-random-secret-min-32-chars

# Initial admin account password set on first startup
ADMIN_DEFAULT_PASSWORD=replace-with-a-strong-admin-password

# Comma-separated list of allowed CORS origins (never use *)
ALLOWED_ORIGINS=replace-with-your-frontend-origins

# Directory path for database backups
BACKUP_DIR=replace-with-your-backup-directory-path

# Production hostname for post-deploy health checks (no trailing slash)
DEPLOY_HOST=replace-with-your-deployed-api-url

# =======================================================================
# OPTIONAL — defaults applied automatically if not set
# =======================================================================

# Graceful shutdown — seconds to wait for in-flight requests after SIGTERM
# Docker stop_grace_period in docker-compose.yml is set to this + 5s (35s)
SHUTDOWN_TIMEOUT_SECONDS=30

# Auto-scaling (GCP Cloud Run) — see config/cloudrun.yml
# MIN_INSTANCES: keep at least this many warm to avoid cold-start latency
# MAX_INSTANCES: cap on number of instances (controls cost and DB pool usage)
# TARGET_CONCURRENCY: scale up when avg concurrent requests per instance exceeds this
MIN_INSTANCES=1
MAX_INSTANCES=10
TARGET_CONCURRENCY=80

# API Gateway JWT (api_gateway.py) — separate secret from auth_api
GATEWAY_JWT_SECRET=       # <-- paste generated value here

# Auth service and frontend URLs (used in invite / reset email links)
FRONTEND_URL=http://localhost:3001

# -----------------------------------------------------------------------
# Notification Configuration
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# AI API Keys
# -----------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here
# NVIDIA NIM / OpenAI-compatible endpoint key
NVIDIA_API_KEY=nvapi-your-key-here

# Demo Mode (set to false for production)
NOTIFICATION_DEMO_MODE=true
DEMO_MODE=false

# Discord Configuration
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id
DISCORD_ALERT_CHANNEL=alerts
DISCORD_ADMIN_CHANNEL=admin

# Slack Configuration  
SLACK_ENABLED=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_DEFAULT_CHANNEL=#alerts
SLACK_ADMIN_CHANNEL=#admin

# Email Configuration
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_email@company.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=aiops@company.com

# ---------------------------------------------------------------------------
# Auth0 — backend token verification
# Get these from your Auth0 dashboard after creating a tenant + API
# ---------------------------------------------------------------------------
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
# Namespace used for custom JWT claims (role). Must match the Auth0 Action.
AUTH0_NAMESPACE=https://aiops-bot.local

# CORS — ALLOWED_ORIGINS is set in the REQUIRED section above.
# Example local dev value: http://localhost:3000,http://localhost:3001,http://localhost:3002
# Example production value: https://resilo.app,https://app.resilo.ai

# -----------------------------------------------------------------------
# OpenTelemetry — distributed tracing (Jaeger via otel-collector)
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable. Leave unset for console output.
# -----------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_METRIC_EXPORT_INTERVAL_MS=30000
# APP_VERSION=0.0.1
# ENVIRONMENT=development
# OTEL_SERVICE_VERSION=1.0.0
# OTEL_TRACES_SAMPLER=parentbased_always_on

# Redis — required for distributed rate limiting (multi-worker / multi-host)
# REDIS_URL=redis://localhost:6379/0

# API Gateway passwords — NO DEFAULTS. Must be set before starting.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(20))"
GATEWAY_ADMIN_PASSWORD=        # <-- required
GATEWAY_OPERATOR_PASSWORD=     # <-- required
GATEWAY_VIEWER_PASSWORD=       # <-- required

# Deployment configuration (scripts/deploy-cloud.ps1)
GCLOUD_PROJECT_ID=your-gcp-project
GCLOUD_REGION=us-central1
DASHBOARD_URL=https://your-dashboard.example.com
# Optional: provide explicit gcloud path if not on PATH
# GCLOUD_CLI_PATH=C:\\path\\to\\gcloud.cmd

# -----------------------------------------------------------------------
# Post-deploy health verification (scripts/verify_deploy.sh)
# DEPLOY_HOST is set in the REQUIRED section above.
# AUTH_HOST:   base URL of the deployed auth-api (no trailing slash)
# DEPLOY_SLACK_WEBHOOK_URL: Slack incoming webhook for deploy failure alerts
#   Add this as a GitHub Actions secret named DEPLOY_SLACK_WEBHOOK_URL
# -----------------------------------------------------------------------
AUTH_HOST=https://auth-api-<hash>-uc.a.run.app
DEPLOY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/DEPLOY/WEBHOOK

# Admin seeding defaults (scripts/seed_admin.py)
SEED_ADMIN_EMAIL=admin@company.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@1234

# Rate limiting overrides (optional)
# RATE_LIMIT_DEFAULT=100 per minute
# RATE_LIMIT_HOURLY=1000 per hour
# RATE_LIMIT_LOGIN=10 per minute
# RATE_LIMIT_CHAT=30 per minute
# RATE_LIMIT_FORGOT_PW=3 per minute

# Local testing helpers (scripts/test_login.py)
LOGIN_TEST_URL=http://localhost:5000/auth/login
LOGIN_TEST_EMAIL=admin@company.local
LOGIN_TEST_PASSWORD=Admin@1234

# Logging
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# PostgreSQL connection components (used by backup.sh and restore.sh)
# These must match the values embedded in DATABASE_URL above.
# -----------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aiops
POSTGRES_USER=aiops
POSTGRES_PASSWORD=           # <-- same password as in DATABASE_URL

# -----------------------------------------------------------------------
# Backup configuration (scripts/backup.sh)
# BACKUP_DIR is set in the REQUIRED section above.
# -----------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7

# -----------------------------------------------------------------------
# DB startup retry (core_api / auth_api startup behaviour)
# -----------------------------------------------------------------------
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY=3
