# ── Local development defaults ───────────────────────────────────────────────
REACT_APP_API_BASE_URL=http://localhost:3001
REACT_APP_AUTH_API_URL=http://localhost:5001
REACT_APP_CORE_API_URL=http://localhost:3001
REACT_APP_SOCKET_URL=http://localhost:3001
REACT_APP_LOCAL_AGENT_URL=http://localhost:3001/metrics
REACT_APP_DIRECT_MODE=false
REACT_APP_USE_MOCKS=false

# ---------------------------------------------------------------------------
# Firebase — get these from Firebase Console → Project Settings → Your apps
# NEVER commit actual values to source control
# ---------------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=AIzaSy-your-key-here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:your-app-id
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Auth0 — frontend (React SDK)
# Get from Auth0 dashboard → Applications → your SPA
# ---------------------------------------------------------------------------
REACT_APP_AUTH0_DOMAIN=your-tenant.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-spa-client-id
REACT_APP_AUTH0_AUDIENCE=https://your-api-identifier
REACT_APP_AUTH0_NAMESPACE=https://aiops-bot.local
